$\",\"h2\",null,{\"className\":\"text-lg font-semibold text-neutral-900 mb-2\",\"children\":\"4. Who we share your information with\"}],[\"$\",\"p\",null,{\"children\":\"We may share your information with the tutor we match you with, solely for the purpose of facilitating the tutoring relationship. We use Resend (email delivery) and the Meta WhatsApp Business API for internal notifications. Both services process data on our behalf and are bound by their own privacy policies.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-lg font-semibold text-neutral-900 mb-2\",\"children\":\"5. How long we keep your data\"}],[\"$\",\"p\",null,{\"children\":\"We retain your personal information for as long as necessary to fulfil the purpose for which it was collected, or as required by law. If you would like your data deleted, please contact us.\"}]]}],\"$L3\",\"$L4\",\"$L5\"]}]]}],\"$L6\"]}],[\"$L7\"],\"$L8\"]}],\"isPartial\":false,\"staleTime\":300,\"varyParams\":null,\"buildId\":\"beDMPhAJWTgR8rCX85T_Q\"}\n3:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-lg font-semibold text-neutral-900 mb-2\",\"children\":\"6. Your rights\"}],[\"$\",\"p\",null,{\"children\":\"Under POPIA, you have the right to access, correct, or request deletion of your personal information. To exercise these rights, contact us at the address below.\"}]]}]\n4:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-lg font-semibold text-neutral-900 mb-2\",\"children\":\"7. Cookies\"}],[\"$\",\"p\",null,{\"children\":\"We use cookies solely for analytics purposes via Google Analytics 4. You can disable cookies in your browser settings at any time.\"}]]}]\n5:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-lg font-semibold text-neutral-900 mb-2\",\"children\":\"8. Contact\"}],[\"$\",\"p\",null,{\"children\":[\"For any privacy-related questions or requests, please contact us at\",\" \",[\