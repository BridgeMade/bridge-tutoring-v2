{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/page,_N_T_/,_N_T_/index"},"segmentPaths":["/_tree","/_full","/__PAGE__","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\" class=\"geist_db8459eb-module__PZ6jEG__variable h-full antialiased\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/caa3a2e1cccd8315-s.p.0wgildi0cnwt9.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/26-vtkwx7du7u.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/0-5l55wg8eb8f.js\"/><script src=\"/_next/static/chunks/15orcrkp-_9ct.js\" async=\"\"></script><script src=\"/_next/static/chunks/2ncdmtj91g36a.js\" async=\"\"></script><script src=\"/_next/static/chunks/106gf3tkm7-oi.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-3chenhptj0c52.js\" async=\"\"></script><script src=\"/_next/static/chunks/1el5-48au3iai.js\" async=\"\"></script><script src=\"/_next/static/chunks/14mrh2-p_w84d.js\" async=\"\"></script><script src=\"/_next/static/chunks/1rxncug86bump.js\" async=\"\"></script><link rel=\"preload\" href=\"https://www.googletagmanager.com/gtag/js?id=G-2X5RZVJ3WV\" as=\"script\"/><meta name=\"next-size-adjust\" content=\"\"/><title>Bridge Tutoring — Find a Tutor in Pretoria &amp; Johannesburg</title><meta name=\"description\" content=\"Bridge matches your child with a hand-picked tutor in Pretoria and Johannesburg. Request a tutor today and hear back within 24 hours.\"/><meta property=\"og:title\" content=\"Bridge Tutoring\"/><meta property=\"og:description\" content=\"Hand-picked tutors in Pretoria &amp; Johannesburg.\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary\"/><meta name=\"twitter:title\" content=\"Bridge Tutoring\"/><meta name=\"twitter:description\" content=\"Hand-picked tutors in Pretoria &amp; Johannesburg.\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.2vob68tjqpejf.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><script src=\"/_next/static/chunks/0cz1d0mv5g_q7.js\" noModule=\"\"></script></head><body class=\"min-h-full flex flex-col bg-white text-neutral-900\"><div hidden=\"\"><!--$--><!--/$--></div><div class=\"flex flex-col min-h-full\"><header class=\"sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-neutral-100\"><div class=\"mx-auto max-w-6xl px-4 sm:px-6 lg:px-8\"><div class=\"flex h-16 items-center justify-between\"><a class=\"text-xl font-bold tracking-tight text-teal-700\" href=\"/\">Bridge</a><nav class=\"flex items-center gap-2 sm:gap-4\"><a class=\"text-sm font-medium text-neutral-600 hover:text-neutral-900 transition-colors px-3 py-2 rounded-lg hover:bg-neutral-100\" href=\"/become-tutor\">Become a tutor</a><a class=\"text-sm font-semibold bg-teal-600 text-white px-4 py-2 rounded-xl hover:bg-teal-700 transition-colors\" href=\"/request-tutor\">Find a tutor</a></nav></div></div></header><section class=\"bg-teal-700 text-white py-20 sm:py-28\"><div class=\"mx-auto max-w-6xl px-4 sm:px-6 lg:px-8\"><div class=\"max-w-2xl\"><p class=\"text-teal-200 text-sm font-semibold uppercase tracking-widest mb-4\">Pretoria &amp; Johannesburg</p><h1 class=\"text-4xl sm:text-5xl font-bold leading-tight tracking-tight\">Your child deserves a tutor who actually gets them.</h1><p class=\"mt-6 text-lg text-teal-100 leading-relaxed max-w-xl\">Bridge hand-picks the right tutor for your child — no algorithms, no guessing. Just real people making real matches.</p><div class=\"mt-10 flex flex-col sm:flex-row gap-4\"><a class=\"inline-flex items-center justify-center rounded-xl bg-white text-teal-700 font-semibold px-8 py-4 text-base hover:bg-teal-50 transition-colors\" href=\"/request-tutor\">Find a tutor</a><a class=\"inline-flex items-center justify-center rounded-xl border border-teal-400 text-white font-semibold px-8 py-4 text-base hover:bg-teal-600 transition-colors\" href=\"/become-tutor\">Become a tutor</a></div></div></div></section><section class=\"bg-teal-800 text-teal-100 py-4\"><div class=\"mx-auto max-w-6xl px-4 sm:px-6 lg:px-8\"><ul class=\"flex flex-wrap items-center gap-x-8 gap-y-2 text-sm font-medium\"><li class=\"flex items-center gap-2\"><span class=\"text-teal-300\">✓</span> Human-matched, not algorithm-matched</li><li class=\"flex items-center gap-2\"><span class=\"text-teal-300\">✓</span>Pretoria &amp; Johannesburg</li><li class=\"flex items-center gap-2\"><span class=\"text-teal-300\">✓</span> Hear back within 24 hours</li><li class=\"flex items-center gap-2\"><span class=\"text-teal-300\">✓</span>In-person &amp; online</li></ul></div></section><section class=\"py-20 sm:py-24\"><div class=\"mx-auto max-w-6xl px-4 sm:px-6 lg:px-8\"><div class=\"text-center max-w-xl mx-auto mb-14\"><h2 class=\"text-3xl font-bold text-neutral-900\">How Bridge works</h2><p class=\"mt-3 text-neutral-500 text-lg\">Simple, fast, and personal.</p></div><div class=\"grid grid-cols-1 gap-8 sm:grid-cols-3\"><div class=\"rounded-2xl bg-teal-50 p-8\"><span class=\"text-3xl font-bold text-teal-300\">01</span><h3 class=\"mt-4 text-lg font-semibold text-neutral-900\">Tell us what you need</h3><p class=\"mt-2 text-neutral-600 leading-relaxed\">Fill in a short form — grade, subjects, location, and goals. Takes about 3 minutes.</p></div><div class=\"rounded-2xl bg-teal-50 p-8\"><span class=\"text-3xl font-bold text-teal-300\">02</span><h3 class=\"mt-4 text-lg font-semibold text-neutral-900\">We find your match</h3><p class=\"mt-2 text-neutral-600 leading-relaxed\">Our team reviews your request and hand-picks tutors who fit your child&#x27;s needs and schedule.</p></div><div class=\"rounded-2xl bg-teal-50 p-8\"><span class=\"text-3xl font-bold text-teal-300\">03</span><h3 class=\"mt-4 text-lg font-semibold text-neutral-900\">Start learning</h3><p class=\"mt-2 text-neutral-600 leading-relaxed\">We introduce you to your tutor. First session within days, not weeks.</p></div></div><div class=\"mt-10 text-center\"><a class=\"inline-flex items-center justify-center rounded-xl bg-teal-600 text-white font-semibold px-8 py-4 text-base hover:bg-teal-700 transition-colors\" href=\"/request-tutor\">Request a tutor now</a></div></div></section><section class=\"bg-neutral-50 py-20 sm:py-24\"><div class=\"mx-auto max-w-6xl px-4 sm:px-6 lg:px-8\"><div class=\"text-center max-w-xl mx-auto mb-12\"><h2 class=\"text-3xl font-bold text-neutral-900\">Subjects we cover</h2><p class=\"mt-3 text-neutral-500 text-lg\">Grade R through matric — and beyond.</p></div><div class=\"flex flex-wrap gap-3 justify-center\"><span class=\"rounded-full bg-white border border-neutral-200 px-5 py-2 text-sm font-medium text-neutral-700 shadow-sm\">Mathematics</span><span class=\"rounded-full bg-white border border-neutral-200 px-5 py-2 text-sm font-medium text-neutral-700 shadow-sm\">Physical Sciences</span><span class=\"rounded-full bg-white border border-neutral-200 px-5 py-2 text-sm font-medium text-neutral-700 shadow-sm\">Life Sciences</span><span class=\"rounded-full bg-white border border-neutral-200 px-5 py-2 text-sm font-medium text-neutral-700 shadow-sm\">English</span><span class=\"rounded-full bg-white border border-neutral-200 px-5 py-2 text-sm font-medium text-neutral-700 shadow-sm\">Accounting</span><span class=\"rounded-full bg-white border border-neutral-200 px-5 py-2 text-sm font-medium text-neutral-700 shadow-sm\">Geography</span><span class=\"rounded-full bg-white border border-neutral-200 px-5 py-2 text-sm font-medium text-neutral-700 shadow-sm\">History</span><span class=\"rounded-full bg-white border border-neutral-200 px-5 py-2 text-sm font-medium text-neutral-700 shadow-sm\">Afrikaans</span><span class=\"rounded-full bg-white border border-neutral-200 px-5 py-2 text-sm font-medium text-neutral-700 shadow-sm\">Economics</span><span class=\"rounded-full bg-teal-600 text-white px-5 py-2 text-sm font-medium shadow-sm\">+ many more</span></div></div></section><section class=\"py-20 sm:py-24\"><div class=\"mx-auto max-w-6xl px-4 sm:px-6 lg:px-8\"><div class=\"text-center max-w-xl mx-auto mb-14\"><h2 class=\"text-3xl font-bold text-neutral-900\">What parents say</h2></div><div class=\"grid grid-cols-1 gap-6 sm:grid-cols-3\"><div class=\"rounded-2xl bg-neutral-50 p-8\"><p class=\"text-neutral-700 leading-relaxed italic\">“<!-- -->My daughter went from failing Maths to getting 78% in her final exam. The tutor Bridge found was patient and really understood how she learns.<!-- -->”</p><div class=\"mt-6\"><p class=\"text-sm font-semibold text-neutral-900\">Nomsa M.</p><p class=\"text-xs text-neutral-400\">Pretoria East</p></div></div><div class=\"rounded-2xl bg-neutral-50 p-8\"><p class=\"text-neutral-700 leading-relaxed italic\">“<!-- -->I was sceptical about one-on-one tutoring but the results speak for themselves. My son&#x27;s confidence has improved so much.<!-- -->”</p><div class=\"mt-6\"><p class=\"text-sm font-semibold text-neutral-900\">Pieter V.</p><p class=\"text-xs text-neutral-400\">Sandton</p></div></div><div class=\"rounded-2xl bg-neutral-50 p-8\"><p class=\"text-neutral-700 leading-relaxed italic\">“<!-- -->Fast response from Bridge — within a day we had a tutor lined up for Physical Science. Highly recommend.<!-- -->”</p><div class=\"mt-6\"><p class=\"text-sm font-semibold text-neutral-900\">Thandi K.</p><p class=\"text-xs text-neutral-400\">Midrand</p></div></div></div></div></section><section class=\"bg-purple-700 text-white py-20 sm:py-24\"><div class=\"mx-auto max-w-6xl px-4 sm:px-6 lg:px-8\"><div class=\"max-w-2xl\"><h2 class=\"text-3xl font-bold\">Are you a tutor?</h2><p class=\"mt-4 text-purple-100 text-lg leading-relaxed\">Join Bridge and get matched with students who need exactly what you offer. We handle the finding — you handle the teaching.</p><div class=\"mt-8\"><a class=\"inline-flex items-center justify-center rounded-xl bg-white text-purple-700 font-semibold px-8 py-4 text-base hover:bg-purple-50 transition-colors\" href=\"/become-tutor\">Apply to become a tutor</a></div></div></div></section><footer class=\"mt-auto border-t border-neutral-100 bg-neutral-50\"><div class=\"mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12\"><div class=\"grid grid-cols-1 gap-8 sm:grid-cols-3\"><div><span class=\"text-lg font-bold text-teal-700\">Bridge</span><p class=\"mt-2 text-sm text-neutral-500 leading-relaxed\">Hand-picked tutors in Pretoria and Johannesburg. We do the matching — you focus on results.</p></div><div><p class=\"text-sm font-semibold text-neutral-700 mb-3\">Get started</p><ul class=\"space-y-2 text-sm text-neutral-500\"><li><a class=\"hover:text-teal-700 transition-colors\" href=\"/request-tutor\">Find a tutor</a></li><li><a class=\"hover:text-teal-700 transition-colors\" href=\"/become-tutor\">Become a tutor</a></li></ul></div><div><p class=\"text-sm font-semibold text-neutral-700 mb-3\">Legal</p><ul class=\"space-y-2 text-sm text-neutral-500\"><li><a class=\"hover:text-teal-700 transition-colors\" href=\"/privacy\">Privacy policy</a></li></ul></div></div><div class=\"mt-10 border-t border-neutral-200 pt-6 text-xs text-neutral-400\">© <!-- -->2026<!-- -->Bridge Tutoring. All rights reserved. Pretoria &amp; Johannesburg, South Africa.</div></div></footer></div><!--$--><!--/$--><script src=\"/_next/static/chunks/0-5l55wg8eb8f.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[79520,[\\\"/_next/static/chunks/1el5-48au3iai.js\\\",\\\"/_next/static/chunks/14mrh2-p_w84d.js\\\"],\\\"\\\"]\\n3:I[39756,[\\\"/_next/static/chunks/1el5-48au3iai.js\\\",\\\"/_next/static/chunks/14mrh2-p_w84d.js\\\"],\\\"default\\\"]\\n4:I[37457,[\\\"/_next/static/chunks/1el5-48au3iai.js\\\",\\\"/_next/static/chunks/14mrh2-p_w84d.js\\\"],\\